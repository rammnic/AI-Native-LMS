# AI-Native LMS Environment Configuration

# Database (optional - uses mock data when not set)
# DATABASE_URL=postgresql://user:pass@localhost:5432/lms

# JWT Secret for authentication (change in production!)
JWT_SECRET=your-secret-key-change-in-production

# Invite Code for Registration (set to "true" to require invite codes)
INVITE_CODE_REQUIRED=false

# AI Configuration
AI_MOCK_ENABLED=true
OPENROUTER_API_KEY=your_openrouter_api_key_here

# AI Framework URL
AI_API_URL=http://localhost:8000

# AI Models (for course generation and mentoring)
AI_COURSE_MODEL=minimax/minimax-m2.5:nitro
AI_MENTOR_MODEL=minimax/minimax-m2.5:nitro

# AI Token Limits (max_tokens per operation)
AI_MAX_TOKENS_COURSE=8192
AI_MAX_TOKENS_THEORY=4096
AI_MAX_TOKENS_PRACTICE=4096
AI_MAX_TOKENS_MENTOR=2048
AI_MAX_TOKENS_CODE_VALIDATOR=1024
INVITE_CODE_REQUIRED=true

# AI Framework URL
AI_API_URL=http://localhost:8000

# AI Mock Mode (true = use mock responses, false = use real AI)
AI_MOCK_ENABLED=false

# AI Models (for course generation and mentoring)
AI_COURSE_MODEL=minimax/minimax-m2.5:nitro
AI_MENTOR_MODEL=minimax/minimax-m2.5:nitro

# AI Token Limits (max_tokens per operation)
# These are passed to AI Framework and can override pipeline defaults
# AI_MAX_TOKENS_COURSE=8192
# AI_MAX_TOKENS_THEORY=4096
# AI_MAX_TOKENS_PRACTICE=4096
# AI_MAX_TOKENS_MENTOR=2048
# AI_MAX_TOKENS_CODE_VALIDATOR=1024
AI_MAX_TOKENS_COURSE=16384
AI_MAX_TOKENS_THEORY=8192
AI_MAX_TOKENS_PRACTICE=8192
AI_MAX_TOKENS_MENTOR=2048
AI_MAX_TOKENS_CODE_VALIDATOR=2048
